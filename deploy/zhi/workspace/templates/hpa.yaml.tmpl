{{- if .ComponentEnabled "autoscaling" -}}
{{- $ns := .Get "core/namespace" -}}
{{- $release := .Get "core/release-name" -}}
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{ $release }}-gateway
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/name: glyphoxa
    app.kubernetes.io/instance: {{ $release }}
    app.kubernetes.io/component: gateway
    app.kubernetes.io/part-of: glyphoxa
    app.kubernetes.io/managed-by: zhi
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{ $release }}-gateway
  minReplicas: {{ .GetOr "autoscaling/min-replicas" "2" }}
  maxReplicas: {{ .GetOr "autoscaling/max-replicas" "10" }}
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: {{ .GetOr "autoscaling/target-cpu" "70" }}
---
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: {{ $release }}-gateway
  namespace: {{ $ns }}
  labels:
    app.kubernetes.io/name: glyphoxa
    app.kubernetes.io/instance: {{ $release }}
    app.kubernetes.io/component: gateway
    app.kubernetes.io/part-of: glyphoxa
    app.kubernetes.io/managed-by: zhi
spec:
  maxUnavailable: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: glyphoxa
      app.kubernetes.io/instance: {{ $release }}
      app.kubernetes.io/component: gateway
{{- end }}
