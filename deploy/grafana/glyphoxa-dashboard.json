{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Sessions",
      "type": "stat",
      "targets": [
        {
          "expr": "glyphoxa_active_sessions{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{ tenant_id }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active NPCs",
      "type": "stat",
      "targets": [
        {
          "expr": "glyphoxa_active_npcs{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{ tenant_id }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Participants",
      "type": "stat",
      "targets": [
        {
          "expr": "glyphoxa_active_participants{tenant_id=~\"$tenant_id\"}",
          "legendFormat": "{{ tenant_id }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Provider Errors (5m)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(glyphoxa_provider_errors_total{tenant_id=~\"$tenant_id\"}[5m])) by (tenant_id)",
          "legendFormat": "{{ tenant_id }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Pipeline Latencies",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": false },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "title": "STT Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(glyphoxa_stt_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p50 {{ tenant_id }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(glyphoxa_stt_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p95 {{ tenant_id }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(glyphoxa_stt_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p99 {{ tenant_id }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": false },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "title": "LLM Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(glyphoxa_llm_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p50 {{ tenant_id }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(glyphoxa_llm_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p95 {{ tenant_id }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(glyphoxa_llm_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p99 {{ tenant_id }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": false },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "title": "TTS Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(glyphoxa_tts_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p50 {{ tenant_id }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(glyphoxa_tts_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p95 {{ tenant_id }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(glyphoxa_tts_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p99 {{ tenant_id }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": false },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 13,
      "title": "Tool Execution Latency (P50 / P95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(glyphoxa_tool_execution_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p50 {{ tenant_id }}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(glyphoxa_tool_execution_duration_bucket{tenant_id=~\"$tenant_id\"}[5m])) by (le, tenant_id))",
          "legendFormat": "p95 {{ tenant_id }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Provider Requests",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "title": "Provider Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(glyphoxa_provider_requests_total{tenant_id=~\"$tenant_id\"}[5m])) by (provider, kind, tenant_id)",
          "legendFormat": "{{ tenant_id }} / {{ provider }} / {{ kind }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "title": "Provider Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(glyphoxa_provider_errors_total{tenant_id=~\"$tenant_id\"}[5m])) by (provider, kind, tenant_id)",
          "legendFormat": "{{ tenant_id }} / {{ provider }} / {{ kind }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "NPC & Tool Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 30,
      "title": "NPC Utterance Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(glyphoxa_npc_utterances_total{tenant_id=~\"$tenant_id\"}[5m])) by (npc_id, tenant_id)",
          "legendFormat": "{{ tenant_id }} / {{ npc_id }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 31,
      "title": "Tool Call Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(glyphoxa_tool_calls_total{tenant_id=~\"$tenant_id\"}[5m])) by (tool, status, tenant_id)",
          "legendFormat": "{{ tenant_id }} / {{ tool }} ({{ status }})"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["glyphoxa", "multi-tenant"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(glyphoxa_active_sessions, tenant_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": true,
        "name": "tenant_id",
        "query": "label_values(glyphoxa_active_sessions, tenant_id)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Glyphoxa — Per-Tenant Overview",
  "uid": "glyphoxa-tenant-overview"
}
